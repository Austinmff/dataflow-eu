{
  "suite_name": "gold_eu_indicators_suite",
  "description": "Validates the Gold wide table consumed directly by the Streamlit dashboard.",
  "table": "gold.gold_eu_indicators",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1, "max_value": 50000 }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["country_code", "year", "month"] }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "country_code" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "unemployment_rate_pct",
        "min_value": 0,
        "max_value": 100,
        "mostly": 0.99
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "gdp_per_capita_eur",
        "min_value": 0,
        "max_value": 200000,
        "mostly": 0.99
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "dbt_updated_at" }
    }
  ]
}
