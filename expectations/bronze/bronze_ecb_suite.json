{
  "suite_name": "bronze_ecb_suite",
  "description": "Validates raw ECB data immediately after extraction, before any transformation.",
  "table": "bronze.bronze_ecb",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1, "max_value": 50000 }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "source" }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "source", "value_set": ["ecb"] }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "series_key" }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": { "column": "series_key", "min_value": 5, "max_value": 100 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "year", "min_value": 2019, "max_value": 2030 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "month", "min_value": 1, "max_value": 12 }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "extracted_at" }
    }
  ]
}
