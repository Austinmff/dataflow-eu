{
  "suite_name": "silver_eurostat_suite",
  "description": "Validates cleaned Eurostat data after deduplication and type casting.",
  "table": "silver.silver_eurostat",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1, "max_value": 500000 }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["dataset", "country_code", "year", "month"] }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "value" }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": { "column": "value", "type_": "float" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "value",
        "min_value": -50,
        "max_value": 200000,
        "mostly": 0.99,
        "_comment": "Wide range to accommodate GDP (thousands) and rates (-50 to 100). mostly=0.99 tolerates rare outliers."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "is_aggregate" }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": { "column": "is_aggregate", "type_": "bool" }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "country_code",
        "regex": "^[A-Z]{2}([_][A-Z0-9]+)?$"
      }
    }
  ]
}
