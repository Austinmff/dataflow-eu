{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECB extraction payload",
  "type": "object",
  "required": ["records"],
  "properties": {
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "series_key", "year", "month"],
        "properties": {
          "source": { "type": "string", "const": "ecb" },
          "series_key": { "type": "string", "minLength": 5 },
          "description": { "type": "string" },
          "period": { "type": ["string", "null"] },
          "year": { "type": "integer", "minimum": 1990, "maximum": 2100 },
          "month": { "type": "integer", "minimum": 1, "maximum": 12 },
          "value": { "type": ["number", "null"] },
          "unit": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
