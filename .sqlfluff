[sqlfluff]
dialect = postgres
templater = jinja
max_line_length = 120
exclude_rules = LT09, LT08, ST06, AL01, AL03, RF04, RF02, ST02

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:rules:references.keywords]
ignore_words = source, value, year, month

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower
