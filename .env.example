# =============================================================================
# DataFlow EU — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_UID=1000
AIRFLOW_GID=0
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here-generate-with-python
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# -----------------------------------------------------------------------------
# PostgreSQL (Warehouse)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dataflow
POSTGRES_USER=dataflow
POSTGRES_PASSWORD=dataflow

# Airflow metadata DB (separate from warehouse)
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# -----------------------------------------------------------------------------
# AWS / LocalStack (Bronze Layer — S3)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-west-1
AWS_ENDPOINT_URL=http://localstack:4566

S3_BUCKET_NAME=dataflow-eu-bronze

# -----------------------------------------------------------------------------
# Slack Alerts (Airflow failure notifications)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# -----------------------------------------------------------------------------
# Great Expectations
# -----------------------------------------------------------------------------
GE_DOCS_SITE_PREFIX=docs/data-quality

# -----------------------------------------------------------------------------
# Pipeline Configuration
# -----------------------------------------------------------------------------
PIPELINE_START_DATE=2019-01-01
PIPELINE_SCHEDULE_INTERVAL=@daily

# Eurostat API (no auth required — public API)
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0

# ECB Data Portal API (no auth required — public API)
ECB_BASE_URL=https://data-api.ecb.europa.eu/service
